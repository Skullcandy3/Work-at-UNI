@page "/google-role"
@rendermode InteractiveServer

@using CampusEatsv2.Infrastructure.Services.CustomerServices
@using CampusEatsv2.Infrastructure.Services.CourierServices
@using CampusEatsv2.Infrastructure.Services.SharedServices
@inject IMediator Mediator
@inject AuthenticationStateService AuthStateService
@inject NavigationManager NavigationManager

<PageTitle>Choose Role - Campus Eats</PageTitle>

<div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-purple-600 to-purple-800 px-4">
    <div class="w-full max-w-md bg-white rounded-lg shadow-2xl p-12">
        <h1 class="text-3xl font-bold text-gray-800 text-center mb-2">Welcome!</h1>
        <p class="text-gray-600 text-center mb-8">How would you like to continue?</p>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
                @ErrorMessage
            </div>
        }

        <div class="flex flex-col gap-4">
            <button @onclick="LoginAsCustomer"
                class="w-full py-3 text-lg font-semibold text-white bg-gradient-to-r from-purple-600 to-purple-700 rounded-lg hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                Continue as Customer
            </button>

            <button @onclick="LoginAsCourier"
                class="w-full py-3 text-lg font-semibold text-white bg-gradient-to-r from-blue-600 to-blue-700 rounded-lg hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                Continue as Courier
            </button>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Name { get; set; }

    private string? ErrorMessage;

    private async Task LoginAsCustomer()
    {
        var customer = await Mediator.Send(new LoginOrRegisterGoogleCustomer.Command
        {
            Email = Email ?? "",
            Name = Name ?? ""
        });
        AuthStateService.SetAuthenticatedCustomer(customer);
        NavigationManager.NavigateTo("/customer/dashboard");
    }

    private async Task LoginAsCourier()
    {
        try
        {
            var courier = await Mediator.Send(new LoginGoogleAsCourier.Command
            {
                Email = Email ?? ""
            });
            AuthStateService.SetAuthenticatedCourier(courier);
            NavigationManager.NavigateTo("/courier/dashboard");
        }
        catch (UnauthorizedAccessException ex)
        {
            ErrorMessage = ex.Message;
        }
        catch (InvalidOperationException)
        {
            NavigationManager.NavigateTo("/customer/apply-courier");
        }
    }
}