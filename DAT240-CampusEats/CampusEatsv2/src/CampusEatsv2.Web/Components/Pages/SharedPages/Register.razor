@page "/register"
@rendermode InteractiveServer

@using CampusEatsv2.Infrastructure.Services.CustomerServices
@using CampusEatsv2.Infrastructure.Services.SharedServices
@using FluentValidation
@inject NavigationManager NavigationManager
@inject IMediator Mediator
@inject AuthenticationStateService AuthStateService

<PageTitle>Register - Campus Eats</PageTitle>

<div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-purple-600 to-purple-800 px-4 py-8">
    <div class="w-full max-w-md bg-white rounded-lg shadow-2xl p-12">
        <div>
            <h1 class="text-3xl font-bold text-gray-800 text-center mb-2">Create Customer Account</h1>
            <p class="text-gray-600 text-center mb-8">Join Campus Eats today as a customer</p>
            
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
                    @ErrorMessage
                </div>
            }

            <EditForm Model="RegisterData" OnValidSubmit="HandleRegister" FormName="RegisterForm">
                <div class="mb-5">
                    <label for="fullname" class="block font-semibold text-gray-800 mb-2 text-sm">Full Name</label>
                    <InputText id="fullname" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100 transition-all" @bind-Value="RegisterData.FullName" placeholder="Enter your full name" />
                </div>

                <div class="mb-5">
                    <label for="email" class="block font-semibold text-gray-800 mb-2 text-sm">Email Address</label>
                    <InputText id="email" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100 transition-all" @bind-Value="RegisterData.Email" placeholder="Enter your email" />
                </div>

                <div class="mb-5">
                    <label for="password" class="block font-semibold text-gray-800 mb-2 text-sm">Password</label>
                    <InputText type="password" id="password" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100 transition-all" @bind-Value="RegisterData.Password" placeholder="Create a password" />
                </div>

                <div class="mb-5">
                    <label for="confirmPassword" class="block font-semibold text-gray-800 mb-2 text-sm">Confirm Password</label>
                    <InputText type="password" id="confirmPassword" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 focus:ring-2 focus:ring-purple-100 transition-all" @bind-Value="RegisterData.ConfirmPassword" placeholder="Confirm your password" />
                    @if (!string.IsNullOrEmpty(PasswordMismatchError))
                    {
                        <p class="text-red-600 text-sm mt-1">@PasswordMismatchError</p>
                    }
                </div>

                <button type="submit" disabled="@IsLoading" class="w-full py-3 text-lg font-semibold text-white bg-gradient-to-r from-purple-600 to-purple-700 rounded-lg hover:shadow-lg hover:-translate-y-1 transition-all duration-300 disabled:opacity-50">
                    @if (IsLoading)
                    {
                        <span>Creating account...</span>
                    }
                    else
                    {
                        <span>Register</span>
                    }
                </button>
            </EditForm>

            <div class="mt-6 pt-6 border-t border-gray-300 text-center space-y-3">
                <p class="text-gray-600 text-sm">Already have an account? <a href="/login" class="font-semibold text-purple-600 hover:text-purple-700 hover:underline">Log in here</a></p>
                <p><a href="/" class="font-semibold text-purple-600 hover:text-purple-700 hover:underline">Back to Home</a></p>
            </div>
        </div>
    </div>
</div>

@code {
    private class RegisterModel
    {
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }

    private RegisterModel RegisterData = new();
    private string? ErrorMessage;
    private string? PasswordMismatchError;
    private bool IsLoading;

    private async Task HandleRegister()
    {
        try
        {
            IsLoading = true;
            // keep the debug message until we verify the handler runs
            PasswordMismatchError = null;

            if (RegisterData.Password != RegisterData.ConfirmPassword)
            {
                PasswordMismatchError = "Passwords do not match.";
                return;
            }

            var command = new RegisterCustomer.RegisterCustomerCommand 
            { 
                FullName = RegisterData.FullName, 
                Email = RegisterData.Email, 
                Password = RegisterData.Password,
            };
            var customer = await Mediator.Send(command);
            AuthStateService.SetAuthenticatedCustomer(customer);
            NavigationManager.NavigateTo("/customer/dashboard");
        }
        catch (ValidationException ex)
        {
            ErrorMessage = "Validation failed: " + string.Join(", ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }
}

