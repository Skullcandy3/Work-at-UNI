@page "/order/{OrderId:guid}"
@rendermode InteractiveServer

@using CampusEatsv2.Core.Models
@using CampusEatsv2.Infrastructure.Services.SharedServices
@using Microsoft.EntityFrameworkCore
@using MediatR

@inject AuthenticationStateService AuthStateService
@inject CampusEatsv2.Infrastructure.AppDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Order Overview - Campus Eats</PageTitle>

@if (!isAuthorized)
{
    <div class="p-8 text-center">Unauthorized</div>
    return;
}

@if (order == null)
{
    <div class="flex min-h-screen items-center justify-center text-gray-400">
        <p>Order not found.</p>
    </div>
    return;
}

<div class="min-h-screen bg-gradient-to-br from-purple-600 via-purple-700 to-indigo-800 px-4 py-10">
    <div class="mx-auto max-w-4xl space-y-8">

        <div class="text-white">
            <h1 class="text-4xl font-bold">Order Overview</h1>
            <p class="mt-2 text-purple-100">Read-only view of your order.</p>
        </div>

        <section class="rounded-3xl bg-white p-6 shadow-xl space-y-6">

            <div class="flex justify-between text-sm text-gray-500">
                <span class="font-mono">Order #@order.OrderId.ToString()[..8]</span>
                <span>@order.CreationTime.ToString("dd MMM yyyy • HH:mm")</span>
            </div>

            <hr />

            <!-- ORDER INFO -->
            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <p class="text-gray-500">Customer ID</p>
                    <p class="font-mono font-semibold text-gray-800">
                        @order.CustomerId.ToString()[..8]
                    </p>
                </div>
                <div>
                    <p class="text-gray-500">Courier ID</p>
                    <p class="font-mono font-semibold text-gray-800">
                        @(order.CourierId == Guid.Empty ? "Unassigned" : order.CourierId.ToString()[..8])
                    </p>
                </div>
                <div>
                    <p class="text-gray-500">Payment Method</p>
                    <p class="font-semibold text-gray-800">@order.Payment?.Method</p>
                </div>
                <div>
                    <p class="text-gray-500">Payment Status</p>
                    <p class="font-semibold text-gray-800">@order.Payment?.Status</p>
                </div>
                <div>
                    <p class="text-gray-500">Pickup Address</p>
                    <p class="font-semibold text-gray-800">@order.PickupAddress</p>
                </div>
                <div>
                    <p class="text-gray-500">Status</p>
                    <span class="inline-block px-3 py-1 rounded-full text-xs font-bold
                        @(order.Status switch {
                            OrderStatus.Submitted => "bg-yellow-100 text-yellow-800",
                            OrderStatus.Accepted  => "bg-blue-100 text-blue-800",
                            OrderStatus.PickedUp  => "bg-purple-100 text-purple-800",
                            OrderStatus.Delivered => "bg-green-100 text-green-800",
                            OrderStatus.Cancelled => "bg-red-100 text-red-800",
                            _                     => "bg-gray-100 text-gray-600"
                        })">
                        @order.Status
                    </span>
                </div>
            </div>

            <hr />

            <!-- ITEMS -->
            <div class="space-y-4">
                <h3 class="font-semibold text-gray-700">Items</h3>

                @foreach (var item in order.OrderItems)
                {
                    <article class="flex gap-6 rounded-3xl border bg-white p-6 shadow-sm">

                        @if (!string.IsNullOrWhiteSpace(item.Product?.ImageUrl))
                        {
                            <img src="@item.Product.ImageUrl"
                                 alt="@item.Product.Title"
                                 class="h-28 w-28 rounded-2xl object-cover" />
                        }
                        else
                        {
                            <div class="flex h-28 w-28 items-center justify-center
                                        rounded-2xl bg-gradient-to-br
                                        from-purple-100 to-indigo-100 text-4xl">
                                🍔
                            </div>
                        }

                        <div class="flex flex-1 flex-col justify-between">
                            <div class="flex justify-between gap-4">
                                <div>
                                    <h4 class="text-xl font-bold text-gray-900">
                                        @item.Product?.Title
                                    </h4>
                                    <p class="mt-1 text-sm text-gray-600">
                                        @item.Product?.Description
                                    </p>
                                </div>
                                <span class="h-fit rounded-full bg-purple-100 px-5 py-2
                                             text-lg font-bold text-purple-700">
                                    @(item.Price * item.Quantity) kr
                                </span>
                            </div>

                            <div class="mt-4 flex flex-wrap gap-3 text-sm">
                                <span class="rounded-full bg-gray-100 px-4 py-2 font-medium">
                                    Qty: @item.Quantity
                                </span>
                                <span class="rounded-full bg-gray-100 px-4 py-2 font-medium">
                                    Unit: @item.Price kr
                                </span>
                                <span class="rounded-full bg-gray-100 px-4 py-2 font-mono text-xs">
                                    ID: @item.ProductId.ToString()[..8]
                                </span>
                            </div>
                        </div>
                    </article>
                }
            </div>

            <!-- Price -->
            <div class="text-right space-y-1 pt-4 border-t">
                <p class="text-sm text-gray-600">Items: @ItemsTotal.ToString("0.00") kr</p>
                <p class="text-sm text-gray-600">Delivery: @order.DeliveryFee.ToString("0.00") kr</p>
                <p class="text-sm text-gray-600">Tip: @order.Tip.ToString("0.00") kr</p>
                <p class="text-2xl font-bold text-purple-700">
                    Total: @(ItemsTotal + order.DeliveryFee + order.Tip) kr
                </p>
            </div>

        </section>
    </div>
</div>

@code {
    [Parameter]
    public Guid OrderId { get; set; }

    private Order? order;
    private bool isAuthorized = false;

    private decimal ItemsTotal =>
        order?.OrderItems.Sum(i => i.Price * i.Quantity) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        order = await DbContext.Orders
            .Include(o => o.OrderItems)
                .ThenInclude(i => i.Product)
            .Include(o => o.Payment)
            .FirstOrDefaultAsync(o => o.OrderId == OrderId);

        if (order is null)
            return;

        var customer = AuthStateService.GetCustomer();
        var courier  = AuthStateService.GetCourier();

        isAuthorized =
            // Customer who owns the order
            (customer is not null && order.CustomerId == customer.CustomerId) ||
            // Courier assigned to it
            (courier is not null && order.CourierId == courier.CourierId) ||
            // Any approved courier can view Submitted orders
            (courier is not null &&
             courier.Status == CourierStatus.Approved &&
             order.Status == OrderStatus.Submitted);
    }
    private void GoBack()
    {
        var destination = AuthStateService.CurrentRole switch
        {
            "Customer" => "/customer/dashboard",
            "Courier"  => "/courier/dashboard",
            "Admin"    => "/admin/dashboard",
            _          => "/home"
        };

        NavigationManager.NavigateTo(destination);
    }
}
