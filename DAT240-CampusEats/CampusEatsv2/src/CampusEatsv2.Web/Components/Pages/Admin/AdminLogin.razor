@page "/admin/login"
@rendermode InteractiveServer

@using CampusEatsv2.Infrastructure.Services.AdminServices
@using CampusEatsv2.Infrastructure.Services.SharedServices
@using FluentValidation
@inject NavigationManager NavigationManager
@inject IMediator Mediator
@inject AuthenticationStateService AuthStateService

<PageTitle>Admin Log In - Campus Eats</PageTitle>

<div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-red-600 to-red-800 px-4">
    <div class="w-full max-w-md bg-white rounded-lg shadow-2xl p-12">
        <div>
            <h1 class="text-3xl font-bold text-gray-800 text-center mb-2">Admin Log In</h1>
            <p class="text-gray-600 text-center mb-8">Sign in to the administration panel</p>
            
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
                    @ErrorMessage
                </div>
            }

            <EditForm Model="LoginCommand" OnValidSubmit="HandleLogin" FormName="AdminLoginForm">
                <div class="mb-5">
                    <label for="email" class="block font-semibold text-gray-800 mb-2 text-sm">Email Address</label>
                    <InputText id="email" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 transition-all" @bind-Value="LoginCommand.Email" placeholder="Enter your admin email" />
                </div>

                <div class="mb-8">
                    <label for="password" class="block font-semibold text-gray-800 mb-2 text-sm">Password</label>
                    <InputText type="password" id="password" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 transition-all" @bind-Value="LoginCommand.Password" placeholder="Enter your password" />
                </div>

                <button type="submit" disabled="@IsLoading" class="w-full py-3 text-lg font-semibold text-white bg-gradient-to-r from-red-600 to-red-700 rounded-lg hover:shadow-lg hover:-translate-y-1 transition-all duration-300 disabled:opacity-50">
                    @if (IsLoading)
                    {
                        <span>Logging in...</span>
                    }
                    else
                    {
                        <span>Log In</span>
                    }
                </button>
            </EditForm>

            <div class="mt-6 pt-6 border-t border-gray-300 text-center space-y-3">
                <p><a href="/" class="font-semibold text-red-600 hover:text-red-700 hover:underline">Back to Home</a></p>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginAdmin.LoginAdminCommand LoginCommand = new();
    private string? ErrorMessage;
    private bool IsLoading;

    private async Task HandleLogin()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = null;

            var result = await Mediator.Send(LoginCommand);
            
            // Set authentication state
            AuthStateService.SetAuthenticatedAdmin(result.Admin);

            // If password change is required, redirect to password change page
            if (result.RequiresPasswordChange)
            {
                NavigationManager.NavigateTo("/admin/change-password");
            }
            else
            {
                NavigationManager.NavigateTo("/admin/dashboard");
            }
        }
        catch (ValidationException ex)
        {
            ErrorMessage = "Validation failed: " + string.Join(", ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (UnauthorizedAccessException ex)
        {
            ErrorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }
}
