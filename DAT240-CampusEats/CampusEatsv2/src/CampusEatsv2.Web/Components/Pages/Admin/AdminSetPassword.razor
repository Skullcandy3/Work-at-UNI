@page "/admin/add-admin/set-password/{SourceType}/{SourceId:guid}"
@rendermode InteractiveServer
@using CampusEatsv2.Core.Models
@using CampusEatsv2.Infrastructure.Services.AdminServices
@using CampusEatsv2.Infrastructure.Services.SharedServices
@using MediatR
@inject AuthenticationStateService AuthStateService
@inject NavigationManager NavigationManager
@inject IMediator Mediator

<PageTitle>Set Initial Password - Admin - Campus Eats</PageTitle>

@if (AuthStateService.GetAdmin() is Admin loggedInAdmin)
{
    <div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-red-600 to-red-800 px-4">
        <div class="w-full max-w-md bg-white rounded-lg shadow-2xl p-12">
            <h1 class="text-3xl font-bold text-gray-800 text-center mb-2">Set Initial Password</h1>
            <p class="text-gray-600 text-center mb-8">
                Set a temporary password for the new admin. They will be required to change it on first login.
            </p>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
                    @ErrorMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded">
                    @SuccessMessage
                </div>
            }

            <div class="mb-5">
                <label class="block font-semibold text-gray-800 mb-2 text-sm">Initial Password</label>
                <input type="password"
                       class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 transition-all"
                       @bind="InitialPassword"
                       placeholder="Minimum 8 characters" />
            </div>

            <div class="mb-8">
                <label class="block font-semibold text-gray-800 mb-2 text-sm">Confirm Password</label>
                <input type="password"
                       class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 transition-all"
                       @bind="ConfirmPassword"
                       placeholder="Confirm initial password" />
            </div>

            <button @onclick="HandleInvite"
                    disabled="@IsLoading"
                    class="w-full py-3 text-lg font-semibold text-white bg-gradient-to-r from-red-600 to-red-700 rounded-lg hover:shadow-lg hover:-translate-y-1 transition-all duration-300 disabled:opacity-50">
                @(IsLoading ? "Inviting..." : "Invite as Admin")
            </button>

            <p class="text-center text-gray-600 text-sm mt-6">
                <button @onclick="GoBack" class="font-semibold text-red-600 hover:text-red-700 hover:underline">
                    Cancel
                </button>
            </p>
        </div>
    </div>
}
else
{
    <div class="p-8 bg-red-100 min-h-screen flex items-center justify-center">
        <div class="bg-white rounded-lg shadow-lg p-8 text-center">
            <p class="text-gray-800 mb-6">You are not authorized to view this page. Please login as an admin.</p>
            <a href="/admin/login" class="bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700">Back to Admin Login</a>
        </div>
    </div>
}

@code {
    [Parameter] public string SourceType { get; set; } = "";
    [Parameter] public Guid SourceId { get; set; }

    private string InitialPassword = "";
    private string ConfirmPassword = "";
    private string? ErrorMessage;
    private string? SuccessMessage;
    private bool IsLoading;

    private async Task HandleInvite()
    {
        ErrorMessage = null;
        SuccessMessage = null;

        var loggedInAdmin = AuthStateService.GetAdmin();
        if (loggedInAdmin is null)
        {
            ErrorMessage = "Session expired. Please log in again.";
            return;
        }

        if (string.IsNullOrWhiteSpace(InitialPassword))
        {
            ErrorMessage = "Please enter an initial password.";
            return;
        }

        if (InitialPassword != ConfirmPassword)
        {
            ErrorMessage = "Passwords do not match.";
            return;
        }

        IsLoading = true;
        try
        {
            var parsedSourceType = Enum.Parse<InviteAdminUser.SourceType>(SourceType);

            var createdAdmin = await Mediator.Send(new InviteAdminUser.InviteAdminUserCommand
            {
                SourceType = parsedSourceType,
                SourceId = SourceId,
                InitialPassword = InitialPassword,
                InvitedByAdminId = loggedInAdmin.AdminId
            });

            SuccessMessage = $"Admin invitation created successfully for {createdAdmin.Email}. Redirecting...";
            await Task.Delay(1500);
            NavigationManager.NavigateTo("/admin/add-admin");
        }
        catch (FluentValidation.ValidationException ex)
        {
            ErrorMessage = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/admin/add-admin");
    }
}