@page "/admin/manage-products"
@rendermode InteractiveServer

@using CampusEatsv2.Core.Models
@using CampusEatsv2.Infrastructure.Services.AdminServices
@using CampusEatsv2.Infrastructure.Services.SharedServices
@using FluentValidation
@inject AuthenticationStateService AuthStateService
@inject NavigationManager NavigationManager
@inject IMediator Mediator

<PageTitle>Manage Products - Campus Eats</PageTitle>

@if (AuthStateService.GetAdmin() is Admin admin)
{
    <div class="min-h-screen bg-gradient-to-br from-red-600 via-red-700 to-orange-700 px-4 py-10">
        <div class="mx-auto max-w-7xl">

            @if (!string.IsNullOrWhiteSpace(FeedbackMessage))
            {
                <div class="@FeedbackBannerClass">
                    <p class="text-sm font-semibold uppercase tracking-[0.2em]">@FeedbackLabel</p>
                    <p class="mt-2 text-base">@FeedbackMessage</p>
                </div>
            }

            <div class="grid grid-cols-1 gap-6 xl:grid-cols-[1.1fr,1.4fr]">
                <section class="rounded-3xl bg-white p-6 shadow-xl">
                    <div class="mb-6 flex items-start justify-between gap-4">
                        <div>
                            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-red-500">
                                @(IsEditing ? "Edit product" : "Create product")
                            </p>
                            <h2 class="mt-2 text-2xl font-bold text-gray-900">@FormTitle</h2>
                            <p class="mt-2 text-sm leading-6 text-gray-600">
                                @(IsEditing
                                    ? "Update the selected product and save your changes back to the menu."
                                    : "Add a new product that customers will be able to browse from the store menu.")
                            </p>
                        </div>

                        @if (IsEditing)
                        {
                            <button @onclick="CancelEdit" class="rounded-full border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-50">
                                Cancel Edit
                            </button>
                        }
                    </div>

                    <EditForm Model="FormModel" OnValidSubmit="SubmitAsync" FormName="ManageProductsForm">
                        <div class="space-y-5">
                            <div>
                                <label for="title" class="mb-2 block text-sm font-semibold text-gray-800">Product title</label>
                                <InputText id="title" @bind-Value="FormModel.Title" class="w-full rounded-2xl border-2 border-gray-200 px-4 py-3 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-100" placeholder="Crispy chicken wrap" />
                            </div>

                            <div>
                                <label for="price" class="mb-2 block text-sm font-semibold text-gray-800">Price</label>
                                <InputNumber id="price" @bind-Value="FormModel.Price" class="w-full rounded-2xl border-2 border-gray-200 px-4 py-3 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-100" placeholder="89" />
                            </div>

                            <div>
                                <label for="deliveryFee" class="mb-2 block text-sm font-semibold text-gray-800">
                                    Delivery Fee
                                </label>
                                <InputNumber id="deliveryFee"
                                             @bind-Value="FormModel.DeliveryFee"
                                             class="w-full rounded-2xl border-2 border-gray-200 px-4 py-3 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-100"
                                             placeholder="20" />
                            </div>

                            <div>
                                <label for="imageUrl" class="mb-2 block text-sm font-semibold text-gray-800">Image URL</label>
                                <InputText id="imageUrl" @bind-Value="FormModel.ImageUrl" class="w-full rounded-2xl border-2 border-gray-200 px-4 py-3 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-100" placeholder="https://example.com/wrap.jpg" />
                            </div>

                            <div class="rounded-3xl border border-gray-100 bg-gray-50 p-4">
                                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-red-500">Image preview</p>
                                <div class="mt-4 overflow-hidden rounded-2xl bg-white shadow-sm">
                                    @if (!string.IsNullOrWhiteSpace(FormModel.ImageUrl))
                                    {
                                        <img src="@FormModel.ImageUrl" alt="Product preview" class="h-56 w-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="flex h-56 items-center justify-center bg-gradient-to-br from-red-100 to-orange-100 text-6xl">
                                            🖼️
                                        </div>
                                    }
                                </div>
                                <p class="mt-3 text-sm leading-6 text-gray-600">
                                    @(string.IsNullOrWhiteSpace(FormModel.ImageUrl)
                                        ? "Paste an image URL to preview how the product card will look."
                                        : "Preview updates live as you adjust the image URL.")
                                </p>
                            </div>

                            <div>
                                <label for="description" class="mb-2 block text-sm font-semibold text-gray-800">Description</label>
                                <InputTextArea id="description" @bind-Value="FormModel.Description" class="min-h-32 w-full rounded-2xl border-2 border-gray-200 px-4 py-3 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-100" placeholder="Describe the product so it looks good on the menu." />
                            </div>

                            <div class="flex flex-wrap gap-3 pt-2">
                                <button type="submit" disabled="@IsSubmitting" class="rounded-full bg-red-600 px-6 py-3 font-semibold text-white transition hover:bg-red-700 disabled:cursor-not-allowed disabled:bg-red-300">
                                    @(IsSubmitting ? "Saving..." : SubmitLabel)
                                </button>

                                <button type="button" @onclick="ResetForm" disabled="@IsSubmitting" class="rounded-full border border-gray-300 px-6 py-3 font-semibold text-gray-700 transition hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-60">
                                    Clear Form
                                </button>
                            </div>
                        </div>
                    </EditForm>
                </section>

                <section class="rounded-3xl bg-white p-6 shadow-xl">
                    <div class="mb-6 flex items-center justify-between gap-4">
                        <div>
                            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-red-500">Current menu items</p>
                            <h2 class="mt-2 text-2xl font-bold text-gray-900">@FilteredProducts.Count product@(FilteredProducts.Count == 1 ? string.Empty : "s")</h2>
                        </div>

                        @if (!IsLoadingProducts && Products.Count > 0)
                        {
                            <div class="rounded-full bg-red-100 px-4 py-2 text-sm font-bold text-red-700">
                                Live menu content
                            </div>
                        }
                    </div>

                    <div class="mb-6 grid grid-cols-1 gap-4 rounded-3xl border border-gray-100 bg-gray-50 p-4 md:grid-cols-[1.4fr,auto] md:items-end">
                        <div>
                            <label for="productSearch" class="mb-2 block text-sm font-semibold text-gray-800">Search products</label>
                            <InputText id="productSearch" @bind-Value="SearchTerm" class="w-full rounded-2xl border-2 border-gray-200 px-4 py-3 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-100" placeholder="Search by title or description" />
                        </div>

                        <label class="flex items-center gap-3 rounded-2xl border border-gray-200 bg-white px-4 py-3 text-sm font-semibold text-gray-700">
                            <InputCheckbox @bind-Value="FilterWithImagesOnly" />
                            Show only products with images
                        </label>
                    </div>

                    @if (IsLoadingProducts)
                    {
                        <div class="space-y-4">
                            @for (var i = 0; i < 3; i++)
                            {
                                <div class="rounded-3xl border border-gray-100 p-4">
                                    <div class="mb-4 h-48 animate-pulse rounded-2xl bg-red-100"></div>
                                    <div class="space-y-3">
                                        <div class="h-6 w-1/2 animate-pulse rounded bg-red-100"></div>
                                        <div class="h-4 w-full animate-pulse rounded bg-gray-100"></div>
                                        <div class="h-4 w-5/6 animate-pulse rounded bg-gray-100"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else if (Products.Count == 0)
                    {
                        <div class="rounded-3xl border border-dashed border-gray-300 bg-gray-50 p-10 text-center">
                            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-red-500">No products yet</p>
                            <h3 class="mt-3 text-2xl font-bold text-gray-900">The menu is currently empty.</h3>
                            <p class="mx-auto mt-3 max-w-xl text-gray-600">
                                Start by creating the first product. It will immediately become available to the customer menu page once saved.
                            </p>
                        </div>
                    }
                    else if (FilteredProducts.Count == 0)
                    {
                        <div class="rounded-3xl border border-dashed border-gray-300 bg-gray-50 p-10 text-center">
                            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-red-500">No matches</p>
                            <h3 class="mt-3 text-2xl font-bold text-gray-900">Nothing matches your current filter.</h3>
                            <p class="mx-auto mt-3 max-w-xl text-gray-600">
                                Try a broader search term or turn off the image-only filter to see the full list again.
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="space-y-4">
                            @foreach (var product in FilteredProducts)
                            {
                                <article class="overflow-hidden rounded-3xl border border-gray-100 shadow-sm transition hover:border-red-200 hover:shadow-md">
                                    @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                    {
                                        <img src="@product.ImageUrl" alt="@product.Title" class="h-56 w-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="flex h-56 items-center justify-center bg-gradient-to-br from-red-100 to-orange-100 text-6xl">
                                            🍔
                                        </div>
                                    }

                                    <div class="p-5">
                                        <div class="mb-4 flex items-start justify-between gap-4">
                                            <div>
                                                <h3 class="text-2xl font-bold text-gray-900">@product.Title</h3>
                                                <p class="mt-2 text-sm leading-6 text-gray-600">@product.Description</p>
                                            </div>
                                            <div class="shrink-0 rounded-full bg-red-100 px-4 py-2 text-sm font-bold text-red-700">
                                                @product.Price.ToString("0.00") kr
                                            </div>
                                            <div class="shrink-0 rounded-full bg-orange-100 px-4 py-2 text-sm font-bold text-orange-700">
                                                Delivery: @product.DeliveryFee.ToString("0.00") kr
                                            </div>
                                        </div>

                                        <div class="mb-4 flex flex-wrap items-center gap-3 text-sm text-gray-500">
                                            <span class="rounded-full bg-gray-100 px-3 py-1 font-medium">ID: @product.ProductId.ToString()[..8]</span>
                                        </div>

                                        <div class="flex flex-wrap gap-3 border-t border-gray-100 pt-4">
                                            <button @onclick="() => BeginEdit(product)" class="rounded-full bg-red-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-700">
                                                Edit
                                            </button>
                                            <button
                                                @onclick="() => DeleteProductAsync(product)"
                                                disabled="@DeletingProductIds.Contains(product.ProductId)"
                                                class="rounded-full border border-red-200 px-4 py-2 text-sm font-semibold text-red-600 transition hover:bg-red-50 disabled:cursor-not-allowed disabled:opacity-60">
                                                @(DeletingProductIds.Contains(product.ProductId) ? "Deleting..." : "Delete")
                                            </button>
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>
            </div>
        </div>
    </div>
}
else
{
    <div class="p-8 bg-red-100 min-h-screen flex items-center justify-center">
        <div class="bg-white rounded-lg shadow-lg p-8 text-center">
            <p class="text-gray-800 mb-6">You are not authorized to view this page. Please login as an admin.</p>
            <a href="/admin/login" class="bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700">Back to Admin Login</a>
        </div>
    </div>
}

@code {
    private sealed class ProductFormModel
    {
        public string Title { get; set; } = string.Empty;
        public decimal Price { get; set; }
        public decimal DeliveryFee { get; set; }
        public string ImageUrl { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }

    private List<Product> Products { get; set; } = [];
    private ProductFormModel FormModel { get; set; } = new();
    private HashSet<Guid> DeletingProductIds { get; } = [];
    private Guid? EditingProductId { get; set; }
    private string SearchTerm { get; set; } = string.Empty;
    private bool FilterWithImagesOnly { get; set; }
    private bool IsLoadingProducts { get; set; } = true;
    private bool IsSubmitting { get; set; }
    private bool FeedbackSucceeded { get; set; }
    private string? FeedbackMessage { get; set; }

    private bool IsEditing => EditingProductId.HasValue;
    private IReadOnlyList<Product> FilteredProducts => Products
        .Where(product => string.IsNullOrWhiteSpace(SearchTerm)
            || product.Title.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
            || product.Description.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(product => !FilterWithImagesOnly || !string.IsNullOrWhiteSpace(product.ImageUrl))
        .ToList();
    private string FormTitle => IsEditing ? "Update product details" : "Create a new menu item";
    private string SubmitLabel => IsEditing ? "Save Changes" : "Create Product";
    private string FeedbackLabel => FeedbackSucceeded ? "Success" : "Attention";
    private string FeedbackBannerClass => FeedbackSucceeded
        ? "mb-6 rounded-3xl border border-emerald-200 bg-white p-5 text-emerald-700 shadow-lg"
        : "mb-6 rounded-3xl border border-red-200 bg-white p-5 text-red-700 shadow-lg";

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        if (AuthStateService.GetAdmin() is null)
        {
            IsLoadingProducts = false;
            Products = [];
            return;
        }

        try
        {
            IsLoadingProducts = true;
            FeedbackMessage = null;
            Products = await Mediator.Send(new ManageProductsAdmin.GetProductsQuery());
        }
        catch (Exception ex)
        {
            FeedbackSucceeded = false;
            FeedbackMessage = $"Could not load products: {ex.Message}";
            Products = [];
        }
        finally
        {
            IsLoadingProducts = false;
        }
    }

    private async Task SubmitAsync()
    {
        try
        {
            IsSubmitting = true;
            FeedbackMessage = null;

            if (IsEditing)
            {
                await Mediator.Send(new ManageProductsAdmin.UpdateProductCommand
                {
                    ProductId = EditingProductId!.Value,
                    Title = FormModel.Title.Trim(),
                    Price = FormModel.Price,
                    DeliveryFee = FormModel.DeliveryFee,
                    ImageUrl = FormModel.ImageUrl.Trim(),
                    Description = FormModel.Description.Trim()
                });

                FeedbackSucceeded = true;
                FeedbackMessage = $"{FormModel.Title.Trim()} was updated successfully.";
            }
            else
            {
                await Mediator.Send(new ManageProductsAdmin.CreateProductCommand
                {
                    ProductId = Guid.NewGuid(),
                    Title = FormModel.Title.Trim(),
                    Price = FormModel.Price,
                    DeliveryFee = FormModel.DeliveryFee,
                    ImageUrl = FormModel.ImageUrl.Trim(),
                    Description = FormModel.Description.Trim()
                });

                FeedbackSucceeded = true;
                FeedbackMessage = $"{FormModel.Title.Trim()} was added to the menu.";
            }

            await LoadProductsAsync();
            ResetForm();
        }
        catch (ValidationException ex)
        {
            FeedbackSucceeded = false;
            FeedbackMessage = "Validation failed: " + string.Join(", ", ex.Errors.Select(error => error.ErrorMessage));
        }
        catch (Exception ex)
        {
            FeedbackSucceeded = false;
            FeedbackMessage = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void BeginEdit(Product product)
    {
        EditingProductId = product.ProductId;
        FeedbackMessage = null;
        FormModel = new ProductFormModel
        {
            Title = product.Title,
            Price = product.Price,
            DeliveryFee = product.DeliveryFee,
            ImageUrl = product.ImageUrl,
            Description = product.Description
        };
    }

    private async Task DeleteProductAsync(Product product)
    {
        try
        {
            DeletingProductIds.Add(product.ProductId);
            FeedbackMessage = null;

            await Mediator.Send(new ManageProductsAdmin.DeleteProductCommand
            {
                ProductId = product.ProductId
            });

            if (EditingProductId == product.ProductId)
            {
                ResetForm();
            }

            FeedbackSucceeded = true;
            FeedbackMessage = $"{product.Title} was removed from the menu.";
            await LoadProductsAsync();
        }
        catch (Exception ex)
        {
            FeedbackSucceeded = false;
            FeedbackMessage = $"Could not delete {product.Title}: {ex.Message}";
        }
        finally
        {
            DeletingProductIds.Remove(product.ProductId);
        }
    }

    private void CancelEdit()
    {
        ResetForm();
        FeedbackMessage = null;
    }

    private void ResetForm()
    {
        EditingProductId = null;
        FormModel = new ProductFormModel();
    }
}
