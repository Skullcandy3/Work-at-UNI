@page "/admin/change-password"
@rendermode InteractiveServer
@using CampusEatsv2.Core.Models
@using CampusEatsv2.Infrastructure.Services.AdminServices
@using CampusEatsv2.Infrastructure.Services.SharedServices
@using MediatR
@inject AuthenticationStateService AuthStateService
@inject NavigationManager NavigationManager
@inject IMediator Mediator

<PageTitle>Change Password - Admin - Campus Eats</PageTitle>

@if (AuthStateService.GetAdmin() is Admin admin)
{
    <div class="flex items-center justify-center min-h-screen bg-gradient-to-br from-red-600 to-red-800 px-4">
        <div class="w-full max-w-md bg-white rounded-lg shadow-2xl p-12">
            <h1 class="text-3xl font-bold text-gray-800 text-center mb-2">Change Password</h1>
            <p class="text-gray-600 text-center mb-8">This is your first login. Please set a new password.</p>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="mb-6 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
                    @ErrorMessage
                </div>
            }
            @if (!string.IsNullOrEmpty(SuccessMessage))
            {
                <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded">
                    @SuccessMessage
                </div>
            }

            <div class="mb-5">
                <label class="block font-semibold text-gray-800 mb-2 text-sm">New Password</label>
                <input type="password"
                       class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 transition-all"
                       @bind="NewPassword"
                       placeholder="Enter new password (8–32 characters)" />
            </div>

            <div class="mb-8">
                <label class="block font-semibold text-gray-800 mb-2 text-sm">Confirm Password</label>
                <input type="password"
                       class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-red-600 focus:ring-2 focus:ring-red-100 transition-all"
                       @bind="ConfirmPassword"
                       placeholder="Confirm new password" />
            </div>

            <button @onclick="HandleChangePassword"
                    disabled="@IsLoading"
                    class="w-full py-3 text-lg font-semibold text-white bg-gradient-to-r from-red-600 to-red-700 rounded-lg hover:shadow-lg hover:-translate-y-1 transition-all duration-300 disabled:opacity-50">
                @(IsLoading ? "Updating..." : "Update Password")
            </button>

            <p class="text-center text-gray-600 text-sm mt-6">
                <button @onclick="Logout" class="font-semibold text-red-600 hover:text-red-700 hover:underline">
                    Logout
                </button>
            </p>
        </div>
    </div>
}
else
{
    <div class="p-8 bg-red-100 min-h-screen flex items-center justify-center">
        <div class="bg-white rounded-lg shadow-lg p-8 text-center">
            <p class="text-gray-800 mb-6">You are not authorized to view this page.</p>
            <a href="/admin/login" class="bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700">Back to Admin Login</a>
        </div>
    </div>
}

@code {
    private string NewPassword = "";
    private string ConfirmPassword = "";
    private string? ErrorMessage;
    private string? SuccessMessage;
    private bool IsLoading;

    private async Task HandleChangePassword()
    {
        ErrorMessage = null;
        SuccessMessage = null;

        // Frontend password validation
        if (string.IsNullOrWhiteSpace(NewPassword) || string.IsNullOrWhiteSpace(ConfirmPassword))
        {
            ErrorMessage = "Please fill in both password fields.";
            return;
        }

        if (NewPassword.Length < 8 || NewPassword.Length > 32)
        {
            ErrorMessage = "Password must be between 8 and 32 characters.";
            return;
        }

        if (NewPassword != ConfirmPassword)
        {
            ErrorMessage = "Passwords do not match.";
            return;
        }

        var admin = AuthStateService.GetAdmin(); 
        if (admin is null)
        {
            ErrorMessage = "Session expired. Please log in again.";
            return;
        }

        IsLoading = true;
        try
        {
            var updatedAdmin = await Mediator.Send(new ForcePasswordChangeAdmin.ForcePasswordChangeCommand
            {
                AdminId = admin.AdminId,
                NewPassword = NewPassword,
            });

            AuthStateService.SetAuthenticatedAdmin(updatedAdmin);

            AuthStateService.ClearPasswordChangeRequirement();

            SuccessMessage = "Password changed successfully! Redirecting...";
            await Task.Delay(1500);
            NavigationManager.NavigateTo("/admin/dashboard");
        }
        catch (FluentValidation.ValidationException ex)
        {
            ErrorMessage = string.Join(" ", ex.Errors.Select(e => e.ErrorMessage));
        }
        catch (InvalidOperationException ex)
        {
            ErrorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void Logout()
    {
        AuthStateService.Logout();
        NavigationManager.NavigateTo("/admin/login");
    }
}