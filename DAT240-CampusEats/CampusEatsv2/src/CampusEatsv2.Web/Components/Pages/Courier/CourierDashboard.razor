@page "/courier/dashboard"
@rendermode InteractiveServer

@using CampusEatsv2.Core.Models
@using CampusEatsv2.Infrastructure.Services.CourierServices
@using CampusEatsv2.Infrastructure.Services.OrderServices
@using CampusEatsv2.Infrastructure.Services.SharedServices
@using MediatR

@inject AuthenticationStateService AuthStateService
@inject NavigationManager NavigationManager
@inject IMediator Mediator

<PageTitle>Courier Dashboard - Campus Eats</PageTitle>

@if (AuthStateService.GetCourier() is Courier courier)
{
    if (courier.Status != CourierStatus.Approved)
    {
        <div class="min-h-screen flex items-center justify-center bg-blue-100">
            <div class="bg-white p-8 rounded-xl shadow text-center">
                <h2 class="text-2xl font-bold mb-4">Registration Pending</h2>
                <p>Status: <strong>@courier.Status</strong></p>
                <button class="mt-6 bg-blue-600 text-white px-6 py-2 rounded"
                        @onclick="Logout">
                    Logout
                </button>
            </div>
        </div>
        return;
    }

    <div class="min-h-screen bg-gradient-to-br from-blue-600 to-blue-800 p-8">
        <div class="max-w-7xl mx-auto">

            <h1 class="text-4xl font-bold text-white mb-8">
                Welcome, @courier.FullName 
            </h1>

            <div class="bg-white rounded-2xl shadow-xl p-6">
                <h2 class="text-xl font-bold mb-6">Available Orders</h2>

                <table class="w-full text-sm border-collapse">
                    <thead>
                        <tr class="border-b text-gray-500">
                            <th class="py-3 text-left">Order</th>
                            <th class="py-3 text-left">Courier</th>
                            <th class="py-3 text-right">Price</th>
                            <th class="py-3 text-right">Fee</th>
                            <th class="py-3 text-right">Earnings</th>
                            <th class="py-3 text-center">Status</th>
                            <th class="py-3 text-right">Actions</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y">
                        @foreach (var order in VisibleOrders)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="py-3 font-mono">
                                    #@order.OrderId.ToString()[..8]
                                </td>

                                <td class="py-3">
                                    @(order.CourierId == Guid.Empty
                                        ? "Unassigned"
                                        : "Assigned")
                                </td>

                                <td class="py-3 text-right">
                                    @order.TotalAmount.ToString("0.00") kr
                                </td>

                                <td class="py-3 text-right">
                                    @order.DeliveryFee.ToString("0.00") kr
                                </td>

                                <td class="py-3 text-right font-semibold">
                                    @((PaymentRules.CalculateCourierEarning(order.DeliveryFee, order.Tip, order.Status)).ToString("0.00")) kr
                                </td>

                                <td class="py-3 text-center">
                                    <span class="px-3 py-1 rounded-full text-xs font-bold
                                        @(order.Status switch {
                                            OrderStatus.Submitted => "bg-yellow-100 text-yellow-800",
                                            OrderStatus.Accepted => "bg-blue-100 text-blue-800",
                                            OrderStatus.PickedUp => "bg-purple-100 text-purple-800",
                                            OrderStatus.Delivered => "bg-green-100 text-green-800",
                                            _ => "bg-gray-100 text-gray-600"
                                        })">
                                        @order.Status
                                    </span>
                                </td>

                                <td class="py-3 text-right space-x-2">
                                    @if (order.Status == OrderStatus.Submitted && !HasActiveOrder)
                                    {
                                        <button class="bg-green-600 text-white px-4 py-1 rounded"
                                                @onclick="() => Accept(order.OrderId)">
                                            Accept
                                        </button>
                                    }

                                    @if (order.Status == OrderStatus.Accepted &&
                                         order.CourierId == courier.CourierId)
                                    {
                                        <button class="bg-yellow-500 text-white px-4 py-1 rounded"
                                                @onclick="() => Pickup(order.OrderId)">
                                            Pick up
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!VisibleOrders.Any())
                {
                    <p class="text-gray-400 text-center py-6">
                        No orders available right now
                    </p>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="p-8 text-center">Unauthorized</div>
}

@code {
    private List<Order> Orders = new();

    private bool HasActiveOrder =>
        Orders.Any(o =>
            o.CourierId == AuthStateService.GetCourier()?.CourierId &&
            (o.Status == OrderStatus.Accepted || o.Status == OrderStatus.PickedUp)
        );

    private IEnumerable<Order> VisibleOrders =>
        Orders.Where(o =>
            o.Status == OrderStatus.Submitted ||
            (o.CourierId == AuthStateService.GetCourier()?.CourierId &&
             (o.Status == OrderStatus.Accepted || o.Status == OrderStatus.PickedUp))
        );

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        Orders = await Mediator.Send(new GetOrdersQuery());
    }

    private async Task Accept(Guid orderId)
    {
        var courier = AuthStateService.GetCourier();
        if (courier is null)
            return;

        await Mediator.Send(new AcceptOrder.AcceptOrderCommand
        {
            CourierId = courier.CourierId,
            OrderId = orderId
        });

        await LoadOrders();
    }

    private async Task Pickup(Guid orderId)
    {
        var courier = AuthStateService.GetCourier();
        if (courier is null)
            return;
    await Mediator.Send(new PickupOrder.PickupOrderCommand
    {
        CourierId = courier.CourierId,
        OrderId = orderId
    });

        await LoadOrders();
    }

    private void Logout()
    {
        AuthStateService.Logout();
        NavigationManager.NavigateTo("/");
    }
}